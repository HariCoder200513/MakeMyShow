generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  OWNER
}

enum SeatType {
  REGULAR
  PREMIUM
  RECLINER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id          String       @id @default(uuid())
  name        String
  username    String       @unique
  email       String       @unique
  password    String?
  role        Role         @default(USER)
  credentials Credential[]
  challenges  Challenge[]
  theaters    Theater[]
  movies      Movie[]
  bookings    Booking[]
  createdAt   DateTime     @default(now())
}

model Credential {
  id           String    @id @default(uuid())
  name         String?
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   String[]
  backedUp     Boolean   @default(false)
  deviceType   String?
  lastUsedAt   DateTime?
  lastUsedIp   String?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Challenge {
  id        String   @id @default(uuid())
  kind      String
  challenge String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  username  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([kind, username])
  @@index([kind, userId])
}

model Movie {
  id          String @id @default(uuid())
  title       String
  description String
  duration    Int
  genre       String
  language    String
  posterUrl   String
  ownerId     String?
  owner       User?  @relation(fields: [ownerId], references: [id])
  shows       Show[]
}

model Theater {
  id      String   @id @default(uuid())
  name    String
  city    String
  ownerId String
  owner   User     @relation(fields: [ownerId], references: [id])
  screens Screen[]
}

model Screen {
  id        String  @id @default(uuid())
  name      String
  theaterId String
  theater   Theater @relation(fields: [theaterId], references: [id])
  seats     Seat[]
  shows     Show[]
}

model Seat {
  id           String        @id @default(uuid())
  row          String
  number       Int
  type         SeatType
  price        Int
  screenId     String
  screen       Screen        @relation(fields: [screenId], references: [id])
  bookingSeats BookingSeat[]

  @@unique([screenId, row, number])
}

model Show {
  id        String    @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  movieId   String
  movie     Movie     @relation(fields: [movieId], references: [id])
  screenId  String
  screen    Screen    @relation(fields: [screenId], references: [id])
  bookings  Booking[]
  bookingSeats BookingSeat[]
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  showId      String
  show        Show          @relation(fields: [showId], references: [id])
  totalAmount Int
  status      BookingStatus
  paymentId   String?
  qrCode      String?
  seats       BookingSeat[]
  createdAt   DateTime      @default(now())
}

model BookingSeat {
  bookingId String
  seatId    String
  showId    String?
  booking   Booking @relation(fields: [bookingId], references: [id])
  seat      Seat    @relation(fields: [seatId], references: [id])
  show      Show?   @relation(fields: [showId], references: [id])

  @@id([bookingId, seatId])
  @@unique([showId, seatId])
  @@index([seatId])
}
